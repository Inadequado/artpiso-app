# Copie para .env.local e preencha (o .env.local NAO vai pro git).
# Fonte de dados do app: 'mock' (dados locais, sem rede) ou 'supabase' (banco real).
VITE_DATA_SOURCE=mock

# Painel Supabase -> Settings -> API (a chave publishable/anon NAO e secreta;
# a service_role NUNCA entra aqui).
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
